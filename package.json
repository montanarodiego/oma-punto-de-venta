{
  "name": "oma-punto-de-venta",
  "version": "1.0.0",
  "description": "Sistema POS híbrido offline/online para Oma",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build:tailwind": "tailwindcss -i ./src/renderer/css/style.css -o ./src/renderer/css/output.css --watch"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "electron": "^29.1.0",
    "firebase": "^10.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "tailwindcss": "^3.4.1"
  }
}
