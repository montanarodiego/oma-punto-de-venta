{
  "name": "oma-punto-de-venta",
  "version": "2.2.1",
  "description": "Sistema POS híbrido offline/online para Oma",
  "author": "OmaTech",
  "main": "src/main/main.js",
  "scripts": {
    "start": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build:renderer": "vite build",
    "dist": "npm run build:renderer && electron-builder --win",
    "dist:dir": "npm run build:renderer && electron-builder --win --dir",
    "test": "node tests/bug1_monto_total.test.js && electron tests/contrato_backend.test.js && electron tests/cobro_integracion.test.js",
    "test:contrato": "electron tests/contrato_backend.test.js",
    "test:cobro": "electron tests/cobro_integracion.test.js"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "firebase": "^10.9.0",
    "framer-motion": "^12.40.0",
    "nodemailer": "^8.0.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.16.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^29.1.0",
    "electron-builder": "^26.8.1",
    "playwright-core": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.omatech.pos",
    "productName": "OmaTech POS",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "OmaTech.POS.Setup.${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OmaTech POS"
    },
    "files": [
      "src/main/**/*",
      "dist/renderer/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "oma-creds.json",
        "to": "oma-creds.json"
      }
    ],
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "montanarodiego",
      "repo": "oma-punto-de-venta",
      "private": false
    }
  }
}
