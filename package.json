{
  "name": "oma-punto-de-venta",
  "version": "1.7.5",
  "description": "Sistema POS híbrido offline/online para Oma",
  "author": "OmaTech",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build:tailwind": "tailwindcss -i ./src/renderer/css/style.css -o ./src/renderer/css/output.css --watch",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --win --dir"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "chart.js": "^4.5.1",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "firebase": "^10.9.0",
    "nodemailer": "^8.0.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^29.1.0",
    "electron-builder": "^26.8.1",
    "playwright-core": "^1.60.0",
    "tailwindcss": "^3.4.1"
  },
  "build": {
    "appId": "com.omatech.pos",
    "productName": "OmaTech POS",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OmaTech POS"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [],
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "montanarodiego",
      "repo": "oma-punto-de-venta",
      "private": false
    }
  }
}
