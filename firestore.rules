rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── CUENTA DE SYNC (proceso main del POS) ────────────────────────────
    // sync@omatech.com — uid fijo del proceso interno de sincronización.
    // Tiene acceso de lectura/escritura a todos los negocios para poder
    // verificar licencias y subir pendientes sin conocer el uid del cliente.
    function esCuentaSync() {
      return request.auth != null
          && request.auth.uid == 'v0M2YY3XEhTkqKNrvZuFjuppQOe2';
    }

    // ── DENEGACIÓN POR DEFECTO ────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── DOCUMENTO RAÍZ DEL NEGOCIO ────────────────────────────────────────
    // negocios/{negocioId}  →  { licencia: { activa, vencimiento } }
    //
    // El campo "licencia" solo puede escribirse desde Firebase Admin SDK o
    // la Firebase Console — nunca desde la app del cliente.
    match /negocios/{negocioId} {
      allow get: if request.auth != null
                 && (request.auth.uid == negocioId || esCuentaSync());

      // Ningún cliente ni la cuenta sync puede escribir el documento raíz.
      allow write: if false;
    }

    // ── SUBCOLECCIÓN: ARTÍCULOS ───────────────────────────────────────────
    match /negocios/{negocioId}/articulos/{docId} {
      allow read, create, update: if request.auth != null
                                  && (request.auth.uid == negocioId || esCuentaSync());
    }

    // ── SUBCOLECCIÓN: CLIENTES ────────────────────────────────────────────
    match /negocios/{negocioId}/clientes/{docId} {
      allow read, create, update: if request.auth != null
                                  && (request.auth.uid == negocioId || esCuentaSync());
    }

    // ── SUBCOLECCIÓN: TRANSACCIONES ───────────────────────────────────────
    match /negocios/{negocioId}/transacciones/{docId} {
      allow read, create, update: if request.auth != null
                                  && (request.auth.uid == negocioId || esCuentaSync());
    }

    // ── SUBCOLECCIÓN: PROVEEDORES ─────────────────────────────────────────
    match /negocios/{negocioId}/proveedores/{docId} {
      allow read, create, update: if request.auth != null
                                  && (request.auth.uid == negocioId || esCuentaSync());
    }

  }
}
