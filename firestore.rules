// ─────────────────────────────────────────────────────────────────────────────
// REGLAS DE FIRESTORE — MODELO CUSTOM TOKEN (post-migración)
//
// Cada cliente se autentica con un custom token cuyo uid == negocioId (lo emite
// OMA Manager /api/activar), así que cada negocio accede SOLO a sus propios datos.
// Ya NO existe la cuenta de sync compartida (esCuentaSync): se eliminó la brecha
// server-side de acceso global.
//
// Para activar estas reglas:  firebase deploy --only firestore:rules
// (requiere estar logueado en Firebase con acceso al proyecto).
//
// Verificación post-deploy (Firebase Console → Firestore → Rules Playground):
//   simular get a negocios/OTRO_ID/articulos con auth.uid = <negocioId propio>
//   → debe dar DENY. Solo negocios/<uid propio>/* debe dar ALLOW.
// ─────────────────────────────────────────────────────────────────────────────
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── DENEGACIÓN POR DEFECTO ────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── DOCUMENTO RAÍZ DEL NEGOCIO ────────────────────────────────────────
    // negocios/{negocioId}  →  { licencia: { activa, vencimiento } }
    // El campo "licencia" solo se escribe desde Firebase Admin SDK / Console.
    match /negocios/{negocioId} {
      allow get:   if request.auth != null && request.auth.uid == negocioId;
      allow write: if false;
    }

    // ── SUBCOLECCIONES DEL NEGOCIO ────────────────────────────────────────
    // Cada negocio accede solo a las suyas. Sin cuenta de sync compartida.
    match /negocios/{negocioId}/articulos/{docId} {
      allow read, create, update: if request.auth != null && request.auth.uid == negocioId;
    }
    match /negocios/{negocioId}/clientes/{docId} {
      allow read, create, update: if request.auth != null && request.auth.uid == negocioId;
    }
    match /negocios/{negocioId}/transacciones/{docId} {
      allow read, create, update: if request.auth != null && request.auth.uid == negocioId;
    }
    match /negocios/{negocioId}/proveedores/{docId} {
      allow read, create, update: if request.auth != null && request.auth.uid == negocioId;
    }

  }
}
